# Bery Chain Configuration

# === REQUIRED FOR PRODUCTION ===

# Your Validator Private Key (Keep this secret!)
# Generate one using: npm run gen-keys
PRIVATE_KEY=your-64-hex-char-private-key

# JWT Secret for auth (min 32 chars, use strong random in production)
JWT_SECRET=your-32-char-minimum-secret-here

# === P2P / NETWORK ===

# Listen address: 0.0.0.0 for production (accept external peers), 127.0.0.1 for local only
LISTEN_ADDRESS=0.0.0.0

# P2P Port (Default: 3000)
P2P_PORT=3000

# API Port (Default: 8080)
API_PORT=8080

# Bootstrap Peers (comma separated multiaddrs) - required for non-first node
# First node: leave empty. Additional nodes: e.g. /ip4/1.2.3.4/tcp/3000/p2p/Qm...
BOOTSTRAP_PEERS=

# Chain Configuration
CHAIN_ID=8379

# === FAUCET (optional, for dev/test) ===
FAUCET_ENABLED=false
# If FAUCET_ENABLED=true, set a secret token to protect the endpoint
FAUCET_TOKEN=

# === CORS (optional) ===
# Comma-separated allowed origins, e.g. https://app.bery.in,https://bery.in
ALLOWED_ORIGINS=
