# =============================================================================
# Bery Chain — Production Configuration
# =============================================================================
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# === REQUIRED FOR PRODUCTION ===

# Validator private key (64 hex chars). Generate: npm run gen-keys
PRIVATE_KEY=

# JWT secret for auth (min 32 chars). Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# === P2P / NETWORK ===

# 0.0.0.0 = accept external peers; 127.0.0.1 = local only
LISTEN_ADDRESS=0.0.0.0

# P2P port (validators connect here)
P2P_PORT=3000

# API port
API_PORT=8080

# Bootstrap peers. First node: empty. Others: /ip4/<IP>/tcp/3000/p2p/<PEER_ID>
BOOTSTRAP_PEERS=

# Chain ID (8379 = Bery)
CHAIN_ID=8379

# === FAUCET (optional) ===
FAUCET_ENABLED=false
# If enabled, set a secret token; clients must send x-faucet-token header
FAUCET_TOKEN=

# === DATABASE (production auth) ===
# PostgreSQL connection string. Empty = use data/users.json
DATABASE_URL=

# === CORS ===
# Comma-separated: https://bery.in,https://app.bery.in
ALLOWED_ORIGINS=

# === FRONTEND BUILD (Docker) ===
# RPC URL for frontend when API is on a different origin
VITE_RPC_URL=
